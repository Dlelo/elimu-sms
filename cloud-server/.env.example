# Copy to cloud-server/.env (which is gitignored) and fill in values.
# Loaded automatically by `make server`, `make synth-corpus`, and
# the Docker run target.

# ── LLM backend ─────────────────────────────────────────────────────────────
# Free tier — Gemini Flash (recommended for low cost):
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_API_KEY=
# Model id — pick whichever your key has access to. List your available
# models with:
#   . cloud-server/.env && curl -s \
#     "https://generativelanguage.googleapis.com/v1beta/models?key=$LLM_API_KEY" \
#     | grep -o '"name": "models/gemini[^"]*"' | head -10
# Common choices (no '-latest' suffix on the OpenAI-compat endpoint):
#   gemini-1.5-flash     — most universal
#   gemini-1.5-flash-8b  — cheapest 1.x
#   gemini-2.0-flash     — newer, still free-tier
#   gemini-2.5-flash     — best quality of the cheap tier
LLM_MODEL=gemini-1.5-flash

# Alternative: self-hosted Ollama (zero marginal cost, slower)
#LLM_BASE_URL=http://localhost:11434/v1
#LLM_API_KEY=ollama
#LLM_MODEL=llama3.2:3b

# Alternative: Groq (free tier, fastest)
#LLM_BASE_URL=https://api.groq.com/openai/v1
#LLM_API_KEY=
#LLM_MODEL=llama-3.1-8b-instant

# ── Server ──────────────────────────────────────────────────────────────────
# Default port. 5051 chosen because 8080 collides with countless other dev
# tools (Tomcat, Jenkins, alternative HTTP servers...). Change here AND in
# elimu-web/vite.config.ts if you pick a different one — the Vite dev
# proxy needs to point at the same port the Flask server is listening on.
#PORT=5051

# ── Federated learning ──────────────────────────────────────────────────────
FL_AGGREGATOR=trimmed_mean
#AUTO_RETRAIN_INTERVAL_HOURS=24
#ADMIN_TOKEN=
